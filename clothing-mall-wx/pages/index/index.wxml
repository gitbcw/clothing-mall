<view class="container">
  <!-- 沉浸式自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px; background-color: rgba(255, 255, 255, {{navOpacity}});">
    <view class="search-btn">
      <view class="search-icon" style="filter: brightness({{navOpacity > 0.5 ? 0 : 1}});"></view>
    </view>
    <view class="nav-right"></view>
  </view>

  <scroll-view class="page-scroll" scroll-y="true" bindscroll="onPageScroll">
    <!-- Banner -->
    <swiper class="banner-swiper" indicator-dots="true" autoplay="true" circular="true" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#ffffff">
      <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="goToScene" data-scene-id="{{item.id}}">
        <image src="{{item.posterUrl}}" mode="aspectFill" class="banner-image" binderror="onHomeImageError" data-source="banner" data-index="{{index}}" />
      </swiper-item>
    </swiper>

    <!-- 活动位 -->
    <view class="activity-section" wx:if="{{activityGoods.length > 0}}">
      <view class="section-header-weekly">
        <text class="section-title-cn">精选活动</text>
        <text class="section-title-en">FEATURED</text>
      </view>
      <scroll-view class="activity-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="activity-item" wx:for="{{activityGoods}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
          <image src="{{item.picUrl}}" mode="aspectFill" class="activity-img" binderror="onHomeImageError" data-source="activityGoods" data-index="{{index}}" />
          <view class="activity-info">
            <text class="activity-name">{{item.name}}</text>
            <text class="activity-price">¥{{item.retailPrice}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 每周上新 (叠在Banner下方) -->
    <view class="weekly-new-section">
      <view class="section-header-weekly">
        <view class="title-weekly">每周上新</view>
        <view class="subtitle-weekly">NEW ARRIVAL</view>
      </view>
      <scroll-view class="weekly-scroll" scroll-x="true">
        <view class="weekly-list">
          <view class="weekly-item" wx:for="{{weeklyNews}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
            <image class="weekly-img" src="{{item.picUrl || defaultImage}}" mode="aspectFill" binderror="onHomeImageError" data-source="weeklyNews" data-index="{{index}}"></image>
            <view class="weekly-info">
              <view class="weekly-title">{{item.name}}</view>
              <view class="weekly-bottom">
                <view class="weekly-price-wrap">
                  <text class="price-symbol">￥</text>
                  <text class="price-num">{{item.retailPrice}}</text>
                  <text class="original-price" wx:if="{{item.counterPrice > item.retailPrice}}">￥{{item.counterPrice}}</text>
                </view>
                <view class="cart-icon-small" catchtap="addToCart" data-id="{{item.id}}"></view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 热销推荐 -->
    <view class="hot-sale-section">
      <view class="section-header">
        <view class="title-wrap">
          <text class="title">热销推荐</text>
          <text class="subtitle">HOT</text>
        </view>
        <view class="view-more">查看更多 ></view>
      </view>
      <scroll-view class="hot-scroll" scroll-x="true">
        <view class="hot-list">
          <view class="hot-item" wx:for="{{hotSales}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
            <image class="hot-img" src="{{item.picUrl || defaultImage}}" mode="aspectFill" binderror="onHomeImageError" data-source="hotSales" data-index="{{index}}"></image>
            <view class="hot-info">
              <view class="hot-title">{{item.name}}</view>
              <view class="hot-price-wrap">
                <text class="price-symbol theme-color">￥</text>
                <text class="price-num theme-color">{{item.retailPrice}}</text>
                <text class="original-price" wx:if="{{item.counterPrice > item.retailPrice}}">￥{{item.counterPrice}}</text>
              </view>
              <view class="buy-btn" catchtap="buyNow" data-id="{{item.id}}">立即购买</view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 穿搭推荐 -->
    <view class="grid-section" wx:if="{{matchRecommends.length > 0}}">
      <view class="section-title-center">
        <view class="title-line"></view>
        <text class="title-text">穿搭推荐</text>
        <view class="title-line"></view>
      </view>
      <view class="grid-list">
        <view class="grid-item" wx:for="{{matchRecommends}}" wx:key="id" bindtap="goToOutfit" data-id="{{item.id}}">
          <image src="{{item.coverPic}}" mode="aspectFill" class="grid-img" binderror="onHomeImageError" data-source="matchRecommends" data-index="{{index}}" />
          <view class="grid-info">
            <text class="grid-name">{{item.title}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 饰饰如意 -->
    <view class="grid-section">
      <view class="section-title-center">
        <view class="line"></view>
        <text>饰饰如意</text>
        <view class="line"></view>
      </view>
      <view class="grid-list">
        <view class="grid-item" wx:for="{{accessories}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
          <image class="grid-img" src="{{item.picUrl || defaultImage}}" mode="aspectFill" binderror="onHomeImageError" data-source="accessories" data-index="{{index}}"></image>
          <view class="grid-info">
            <view class="grid-title">{{item.name}}</view>
            <view class="grid-bottom">
              <view class="grid-price-wrap">
                <text class="price-symbol theme-color">￥</text>
                <text class="price-num theme-color">{{item.retailPrice}}</text>
              </view>
              <view class="cart-icon-small" catchtap="addToCart" data-id="{{item.id}}"></view>
            </view>
          </view>
        </view>
      </view>
      <view class="btn-more-center">查看更多</view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- 悬浮购物车 -->
  <view class="floating-cart" bindtap="goToCart">
    <view class="badge">3</view>
  </view>
</view>
