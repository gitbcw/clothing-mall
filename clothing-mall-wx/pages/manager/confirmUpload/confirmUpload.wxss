.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.image-preview {
  background: #fff;
  padding: 40rpx;
  display: flex;
  justify-content: center;
  position: relative;
}

.preview-img {
  width: 500rpx;
  height: 500rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.ai-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.confidence {
  font-weight: bold;
}

.form-section {
  background: #fff;
  margin-top: 20rpx;
  padding: 0 30rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
  display: flex;
  align-items: center;
}

.form-item:last-child {
  border-bottom: none;
  flex-direction: column;
  align-items: flex-start;
}

.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  text-align: right;
}

.textarea {
  width: 100%;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
  min-height: 150rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.arrow {
  margin-left: 20rpx;
  color: #ccc;
  font-size: 24rpx;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.btn-draft {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border: none;
}

.btn-submit {
  flex: 2;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  border: none;
}

/* SKU 区域 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  color: #667eea;
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.sku-list {
  padding: 20rpx 0;
}

.sku-item {
  margin-bottom: 20rpx;
}

.sku-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sku-input {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #333;
}

.sku-small {
  flex: 0.8;
}

.sku-delete {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  color: #999;
  font-size: 36rpx;
  flex-shrink: 0;
}

.sku-empty {
  padding: 20rpx 0;
}

.sku-empty-text {
  font-size: 26rpx;
  color: #999;
}
