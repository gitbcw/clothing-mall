/* 分类页样式 - 左右分栏布局 */
page {
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f5f5f5;
}

/* 顶部品牌名 */
.brand-header {
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-input {
  display: flex;
  align-items: center;
  height: 64rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-text {
  font-size: 26rpx;
  color: #999;
}

/* 主内容区：左右分栏 */
.main-content {
  flex: 1;
  display: flex;
  height: 0;
}

/* 左侧分类栏 */
.category-sidebar {
  width: 180rpx;
  height: 100%;
  background: #f9f9f9;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  padding: 0 16rpx;
  position: relative;
}

.category-name {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 1.3;
}

.category-item.active {
  background: #fff;
}

.category-item.active .category-name {
  color: #333;
  font-weight: 600;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: #ab956d;
  border-radius: 0 3rpx 3rpx 0;
}

/* 右侧商品滚动区 */
.goods-scroll {
  flex: 1;
  height: 100%;
  background: #fff;
}

/* 商品网格（每行2个） */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
}

.goods-item {
  position: relative;
  width: calc(50% - 8rpx);
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.goods-item:nth-child(odd) {
  margin-right: 16rpx;
}

.goods-image {
  width: 100%;
  height: 340rpx;
  background: #f9f9f9;
}

.goods-info {
  padding: 16rpx;
}

.goods-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  height: 72rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-brief {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 32rpx;
  color: #f44;
  font-weight: 600;
}

.goods-origin-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

/* 加载状态 */
.load-status {
  padding: 30rpx 0;
  text-align: center;
}

.loading text, .no-more text {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 快速加购按钮 - 分类页：白色背景 + 红色图标 */
.quick-cart-btn {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border: 2rpx solid #f44;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(244, 68, 68, 0.15);
  z-index: 10;
}

.quick-cart-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}
