<view class="container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="goBack">
        <view class="back-icon"></view>
      </view>
      <view class="nav-title">{{sceneName}}</view>
      <view class="nav-right"></view>
    </view>
  </view>

  <!-- 导航栏占位 -->
  <view style="height: {{statusBarHeight + navBarHeight}}px;"></view>

  <!-- 场景描述 -->
  <view class="scene-desc" wx:if="{{sceneDesc}}">
    <text>{{sceneDesc}}</text>
  </view>

  <!-- 商品列表（瀑布流） -->
  <view class="goods-content" wx:if="{{leftGoodsList.length > 0 || rightGoodsList.length > 0}}">
    <view class="waterfall-col">
      <view class="goods-card" wx:for="{{leftGoodsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image src="{{item.picUrl}}" mode="widthFix" class="goods-img" binderror="onImageError" data-index="{{index}}" data-col="left" />
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.retailPrice}}</text>
        </view>
      </view>
    </view>
    <view class="waterfall-col">
      <view class="goods-card" wx:for="{{rightGoodsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image src="{{item.picUrl}}" mode="widthFix" class="goods-img" binderror="onImageError" data-index="{{index}}" data-col="right" />
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.retailPrice}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="load-more" wx:elif="{{page > pages && goodsList.length > 0}}">
    <text>没有更多了</text>
  </view>
  <view class="empty" wx:if="{{!loading && goodsList.length === 0}}">
    <text>暂无该场景下的商品</text>
  </view>

  <!-- 底部占位 -->
  <view style="height: calc(100rpx + env(safe-area-inset-bottom));"></view>
</view>
