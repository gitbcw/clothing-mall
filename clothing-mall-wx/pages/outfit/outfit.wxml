<view class="container">
  <!-- 顶部海报轮播 -->
  <view class="outfit-banner">
    <swiper class="banner-swiper" indicator-dots autoplay circular>
      <swiper-item wx:for="{{outfitList}}" wx:key="id" bindtap="onSelectOutfit" data-index="{{index}}">
        <view class="banner-item">
          <image src="{{item.posterUrl}}" class="banner-image" mode="aspectFill"/>
          <view class="banner-info">
            <text class="banner-title">{{item.name}}</text>
            <text class="banner-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 热门穿搭列表 -->
  <view class="outfit-list">
    <view class="section-title">
      <text class="title-text">热门穿搭</text>
    </view>

    <view class="outfit-grid">
      <view
        wx:for="{{outfitList}}"
        wx:key="id"
        class="outfit-card"
        bindtap="onSelectOutfit"
        data-index="{{index}}">
        <view class="outfit-poster">
          <image src="{{item.posterUrl}}" mode="aspectFill" class="outfit-image"/>
          <view class="outfit-badge" wx:if="{{item.sortOrder <= 3}}">TOP{{item.sortOrder}}</view>
        </view>
        <view class="outfit-info">
          <text class="outfit-name">{{item.name}}</text>
          <text class="outfit-desc">{{item.subtitle}}</text>
          <view class="outfit-goods-count">
            <text>{{item.goodsList.length}} 件商品</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-status" wx:if="{{outfitList.length > 0}}">
    <text wx:if="{{loading}}" class="loading-text">加载中...</text>
    <text wx:if="{{finished && outfitList.length > 0}}" class="finished-text">没有更多了</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-status" wx:if="{{!loading && outfitList.length === 0}}">
    <text class="empty-text">暂无穿搭推荐</text>
  </view>

  <!-- 穿搭详情弹窗 -->
  <van-popup show="{{currentOutfit !== null}}" position="right" custom-style="width: 100%; height: 100%;" bind:click-overlay="onCloseOutfitDetail">
    <view class="outfit-detail">
      <!-- 左侧固定商品区域 -->
      <scroll-view class="left-panel" scroll-y>
        <view class="left-header">
          <image src="{{currentOutfit.posterUrl}}" class="detail-poster" mode="aspectFill"/>
          <view class="detail-info">
            <text class="detail-title">{{currentOutfit.name}}</text>
            <text class="detail-subtitle">{{currentOutfit.subtitle}}</text>
          </view>
        </view>

        <view class="goods-list-title">搭配商品</view>

        <!-- 左固定商品列表 -->
        <view class="fixed-goods-list">
          <view
            wx:for="{{relatedGoods}}"
            wx:key="id"
            class="goods-item"
            bindtap="onGoodsTap"
            data-id="{{item.id}}">
            <image src="{{item.picUrl}}" class="goods-image" mode="aspectFill"/>
            <view class="goods-info">
              <text class="goods-name">{{item.name}}</text>
              <text class="goods-price">￥{{item.price}}</text>
            </view>
            <view class="goods-actions">
              <view class="action-btn add-cart" catchtap="onAddToCart" data-id="{{item.id}}">加购</view>
              <view class="action-btn buy-now" catchtap="onBuyNow" data-id="{{item.id}}">购买</view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </van-popup>
</view>