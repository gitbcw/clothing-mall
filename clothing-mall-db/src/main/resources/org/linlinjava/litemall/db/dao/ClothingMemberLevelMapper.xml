<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.linlinjava.litemall.db.dao.ClothingMemberLevelMapper">

    <resultMap id="BaseResultMap" type="org.linlinjava.litemall.db.domain.ClothingMemberLevel">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="min_points" property="minPoints"/>
        <result column="max_points" property="maxPoints"/>
        <result column="discount_rate" property="discountRate"/>
        <result column="points_rate" property="pointsRate"/>
        <result column="icon_url" property="iconUrl"/>
        <result column="description" property="description"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="add_time" property="addTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, min_points, max_points, discount_rate, points_rate, icon_url, description, sort_order, add_time, update_time
    </sql>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM clothing_member_level
        WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM clothing_member_level
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectByPoints" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM clothing_member_level
        WHERE min_points &lt;= #{points}
        AND (max_points IS NULL OR max_points >= #{points})
        ORDER BY sort_order DESC
        LIMIT 1
    </select>

    <insert id="insert" parameterType="org.linlinjava.litemall.db.domain.ClothingMemberLevel" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO clothing_member_level (name, min_points, max_points, discount_rate, points_rate, icon_url, description, sort_order, add_time, update_time)
        VALUES (#{name}, #{minPoints}, #{maxPoints}, #{discountRate}, #{pointsRate}, #{iconUrl}, #{description}, #{sortOrder}, NOW(), NOW())
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="org.linlinjava.litemall.db.domain.ClothingMemberLevel">
        UPDATE clothing_member_level
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="minPoints != null">min_points = #{minPoints},</if>
            <if test="maxPoints != null">max_points = #{maxPoints},</if>
            <if test="discountRate != null">discount_rate = #{discountRate},</if>
            <if test="pointsRate != null">points_rate = #{pointsRate},</if>
            <if test="iconUrl != null">icon_url = #{iconUrl},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteByPrimaryKey">
        DELETE FROM clothing_member_level WHERE id = #{id}
    </delete>

</mapper>
