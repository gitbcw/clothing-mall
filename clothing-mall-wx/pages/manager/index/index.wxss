.container {
  min-height: 100vh;
  background-color: #F7F8FA;
}

/* 顶部头图 */
.header {
  background: linear-gradient(135deg, #BA8D59 0%, #96745A 100%);
  padding: 80rpx 40rpx 60rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -20rpx;
  right: -20rpx;
  height: 80rpx;
  background: #F7F8FA;
  border-radius: 50% 50% 0 0;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  display: block;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 12rpx;
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 数据概览卡片 */
.stats-cards {
  display: flex;
  padding: 0 24rpx;
  margin-top: -30rpx;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #BA8D59, #D4A86C);
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-icon {
  display: none;
}

/* 区块 */
.section {
  padding: 24rpx 24rpx 0;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: #BA8D59;
  border-radius: 3rpx;
}

.more-link {
  font-size: 24rpx;
  color: #BA8D59;
  font-weight: 400;
}

/* 功能菜单 */
.menu-grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 16rpx;
  padding: 12rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  background-size: 40rpx;
  background-repeat: no-repeat;
  background-position: center;
  border-radius: 20rpx;
  background-color: #F7F3EF;
}

.menu-text {
  font-size: 24rpx;
  color: #333;
  margin-top: 12rpx;
  font-weight: 500;
}

.badge {
  position: absolute;
  top: 12rpx;
  right: 24rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #E8494A;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* 最近订单 */
.recent-order {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.recent-order:last-child {
  margin-bottom: 0;
}

.order-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.order-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.order-sn {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.order-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.order-status-text {
  font-size: 24rpx;
  color: #BA8D59;
  font-weight: 500;
  background: rgba(186, 141, 89, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.order-price {
  font-size: 28rpx;
  color: #E8494A;
  font-weight: 600;
  margin-top: 8rpx;
}

