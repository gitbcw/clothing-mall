<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <icon type="search" size="16"></icon>
      <input placeholder="搜索 SKU 名称" value="{{searchKeyword}}" bindconfirm="onSearch" bindinput="onSearchInput" confirm-type="search" />
      <icon type="clear" size="16" wx:if="{{searchKeyword}}" bindtap="clearSearch"></icon>
    </view>
    <view class="filter-btn" bindtap="toggleFilter">
      <text>筛选</text>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel" wx:if="{{showFilter}}">
    <view class="filter-row">
      <text class="filter-label">分类</text>
      <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="filter-value">{{categoryOptions[categoryIndex]}} ></view>
      </picker>
    </view>
    <view class="filter-row">
      <text class="filter-label">状态</text>
      <picker mode="selector" range="{{statusOptions}}" value="{{statusIndex}}" bindchange="onStatusChange">
        <view class="filter-value">{{statusOptions[statusIndex]}} ></view>
      </picker>
    </view>
  </view>

  <!-- SKU 列表 -->
  <view class="sku-list">
    <view class="sku-item" wx:for="{{skuList}}" wx:key="id" bindtap="goSkuDetail" data-id="{{item.id}}">
      <image class="sku-image" src="{{item.sourceImage || '/static/images/default-goods.png'}}" mode="aspectFill"></image>
      <view class="sku-info">
        <view class="sku-name">{{item.name}}</view>
        <view class="sku-meta">
          <text>{{item.category}}</text>
          <text>{{item.color}}</text>
          <text>{{item.size}}</text>
        </view>
        <view class="sku-status status-{{item.status}}">{{item.status === 'draft' ? '草稿' : item.status === 'online' ? '已上架' : '已下架'}}</view>
      </view>
      <view class="sku-actions" catchtap="stopPropagation">
        <button class="action-btn online" wx:if="{{item.status !== 'online'}}" catchtap="quickOnline" data-id="{{item.id}}">上架</button>
        <button class="action-btn offline" wx:if="{{item.status === 'online'}}" catchtap="quickOffline" data-id="{{item.id}}">下架</button>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && skuList.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty" wx:if="{{!loading && skuList.length === 0}}">
      <text>暂无 SKU 数据</text>
    </view>
  </view>
</view>
