/* 川着 transmute 首页样式 */

.container {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 搜索框 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  padding: 20rpx;
}

.search-bar-inner {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  flex: 1;
}

.search-icon {
  font-size: 32rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

/* 轮播图 */
.banner {
  width: 100%;
  height: 400rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 活动位区块（单个活动，5件商品） */
.activity-section {
  background: #fff;
  margin-top: 20rpx;
  padding: 24rpx;
}

.activity-header {
  margin-bottom: 20rpx;
}

.activity-header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.activity-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  position: relative;
  padding-left: 16rpx;
}

.activity-name::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #f44 0%, #ff6b6b 100%);
  border-radius: 3rpx;
}

.activity-more {
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  padding-left: 16rpx;
}

.activity-goods {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-row {
  display: flex;
  gap: 12rpx;
}

.activity-row-top {
  /* 上排2件，等宽 */
}

.activity-row-bottom {
  /* 下排3件 */
}

.activity-goods-item {
  flex: 1;
  background: #fafafa;
  border-radius: 12rpx;
  overflow: hidden;
}

.activity-goods-item-small {
  /* 下排商品略小 */
}

.activity-goods-image {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.activity-row-top .activity-goods-image {
  height: 320rpx;
}

.activity-row-bottom .activity-goods-image {
  height: 220rpx;
}

.activity-goods-info {
  padding: 12rpx;
}

.activity-goods-name {
  display: block;
  font-size: 24rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-goods-price {
  display: block;
  font-size: 26rpx;
  color: #f44;
  font-weight: 500;
  margin-top: 6rpx;
}

/* 通用区块 */
.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 商品网格 */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.goods-item {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.goods-image {
  width: 100%;
  height: 340rpx;
  background: #f9f9f9;
}

.goods-info {
  padding: 16rpx;
}

.goods-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  height: 72rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-brief {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 32rpx;
  color: #f44;
  font-weight: 600;
}

.goods-origin-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

/* 限时特卖 */
.flash-section {
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
}

.flash-scroll {
  white-space: nowrap;
}

.flash-list {
  display: inline-flex;
  padding: 0 4rpx;
  gap: 16rpx;
}

.flash-item {
  display: inline-block;
  width: 240rpx;
  flex-shrink: 0;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(244, 68, 68, 0.1);
}

.flash-image-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
}

.flash-image {
  width: 100%;
  height: 100%;
  background: #f9f9f9;
}

.flash-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #f44 0%, #ff6b6b 100%);
  border-radius: 4rpx;
}

.flash-info {
  padding: 16rpx;
}

.flash-name {
  display: block;
  font-size: 24rpx;
  color: #333;
  height: 66rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.flash-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.flash-price {
  font-size: 28rpx;
  color: #f44;
  font-weight: 600;
}

.flash-origin-price {
  font-size: 20rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.flash-stock {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 穿搭推荐 - 海报滑动 + 左侧商品卡片 */
.outfit-section {
  padding: 24rpx 0;
}

.outfit-swiper {
  width: 100%;
  height: 600rpx;
}

.outfit-card {
  position: relative;
  width: 100%;
  height: 100%;
}

.outfit-poster {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
}

.outfit-goods-panel {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 10;
}

.outfit-goods-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(4px);
}

.outfit-goods-thumb {
  width: 120rpx;
  height: 120rpx;
  background: #f9f9f9;
}

.outfit-goods-price-wrap {
  padding: 8rpx 12rpx;
  background: rgba(244, 68, 68, 0.95);
  width: 100%;
  text-align: center;
}

.outfit-goods-price {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

/* 区块标题 */
.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 底部安全区 */
.safe-bottom {
  height: 40rpx;
}

/* 动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.goods-item, .flash-item {
  animation: fadeInUp 0.3s ease both;
}

/* 快速加购按钮 - 首页：渐变咖啡色背景 + 白色图标 */
.quick-cart-btn {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #AB956D, #8B7355);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(171, 149, 109, 0.3);
  z-index: 10;
}

.quick-cart-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

/* 活动位商品相对定位 */
.activity-goods-item {
  position: relative;
}

/* 穿搭推荐商品卡片相对定位 */
.outfit-goods-card {
  position: relative;
}

/* 热销款商品相对定位 */
.goods-item {
  position: relative;
}
