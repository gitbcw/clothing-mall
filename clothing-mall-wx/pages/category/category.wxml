<view class="container">
  <!-- 沉浸式自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="back-btn" bindtap="goBack">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">商品分类</view>
    <view class="nav-right"></view>
  </view>

  <!-- 搜索栏占位及固定区域 -->
  <view class="header-fixed" style="top: {{statusBarHeight + navBarHeight}}px;">
    <view class="search-bar-wrap" bindtap="goSearch">
      <view class="search-bar">
        <view class="search-icon"></view>
        <text class="search-placeholder">搜索商品</text>
      </view>
    </view>
  </view>

  <!-- 占位符，防止内容被顶部固定区域遮挡 -->
  <view class="nav-placeholder" style="height: {{statusBarHeight + navBarHeight + 54}}px;"></view>

  <!-- 主体内容区：左侧分类，右侧商品 -->
  <view class="main-content">
    <!-- 左侧分类列表 -->
    <scroll-view class="category-sidebar" scroll-y="true">
      <view
        class="category-item {{item.id === activeCategoryId ? 'active' : ''}}"
        wx:for="{{navList}}"
        wx:key="id"
        bindtap="switchCate"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
      <!-- 底部留白 -->
      <view class="sidebar-bottom-placeholder"></view>
    </scroll-view>

    <!-- 右侧商品瀑布流 -->
    <scroll-view class="goods-content" scroll-y="true" lower-threshold="100" bindscrolltolower="loadMore" scroll-top="{{scrollTop}}">
      <view class="waterfall-layout">
        <!-- 左列 -->
        <view class="waterfall-col">
          <view class="goods-card" wx:for="{{leftGoodsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
            <image class="goods-img" src="{{item.picUrl || defaultImage}}" mode="aspectFill" binderror="onCategoryImageError" data-source="leftGoodsList" data-index="{{index}}"></image>
            <view class="goods-info">
              <view class="goods-title">{{item.name}}</view>
              <view class="goods-bottom">
                <view class="price-wrap">
                  <text class="price-symbol theme-color">￥</text>
                  <text class="price-num theme-color">{{item.retailPrice}}</text>
                  <text class="original-price" wx:if="{{item.counterPrice > item.retailPrice}}">￥{{item.counterPrice}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 右列 -->
        <view class="waterfall-col">
          <view class="goods-card" wx:for="{{rightGoodsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
            <image class="goods-img" src="{{item.picUrl || defaultImage}}" mode="aspectFill" binderror="onCategoryImageError" data-source="rightGoodsList" data-index="{{index}}"></image>
            <view class="goods-info">
              <view class="goods-title">{{item.name}}</view>
              <view class="goods-bottom">
                <view class="price-wrap">
                  <text class="price-symbol theme-color">￥</text>
                  <text class="price-num theme-color">{{item.retailPrice}}</text>
                  <text class="original-price" wx:if="{{item.counterPrice > item.retailPrice}}">￥{{item.counterPrice}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <!-- 底部留白，防止被 TabBar 遮挡 -->
      <view class="content-bottom-placeholder"></view>
    </scroll-view>
  </view>
</view>
