.container {
  height: 100vh;
  box-sizing: border-box;
}
/* 重置微信原生 button 默认样式 */
button {
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}
button::after {
  display: none;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: #f4f4f4;
  z-index: 999;
}

.nav-inner {
  height: 48px;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.nav-left,
.nav-right {
  width: 56px;
  height: 48px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-left-hover {
  opacity: 0.6;
}

.arrow {
  width: 12px;
  height: 12px;
  border-left: 2px solid #333;
  border-bottom: 2px solid #333;
  transform: rotate(45deg);
}

.nav-center {
  flex: 1;
  height: 48px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-title {
  max-width: 70%;
  font-size: 17px;
  color: #333;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.login-box {
  width: 100%;
  height: auto;
  overflow: hidden;
  padding: 0 40rpx;
  margin-top: 150rpx;
  background: #f4f4f4;
  box-sizing: border-box;
}

/* 手动输入表单样式 */
.form-group {
  width: 100%;
  margin-bottom: 60rpx;
}

.form-item {
  position: relative;
  display: flex;
  align-items: center;
  height: 100rpx;
  background: #fff;
  border-radius: 50rpx;
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.input-icon {
  font-size: 40rpx;
  color: #666;
  margin-right: 20rpx;
}

.mobile-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #333;
}

.clear-icon {
  padding: 20rpx;
  font-size: 32rpx;
  color: #999;
}

.manual-bind-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  color: #fff;
  border-radius: 50rpx;
  background: #ff8096;
  text-align: center;
  letter-spacing: 3rpx;
}

/* 分割线样式 */
.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0;
}

.divider .line {
  width: 150rpx;
  height: 1px;
  background: #ddd;
}

.divider .text {
  font-size: 26rpx;
  color: #999;
  margin: 0 30rpx;
}

.phone-login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  color: #ff8096;
  border: 1px solid #ff8096;
  border-radius: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  letter-spacing: 3rpx;
  background: transparent;
}
