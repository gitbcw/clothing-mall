@import "../../../styles/manager-common.wxss";

.container {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 140rpx;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.nav-back {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  /* 动态高度 */
}

/* 草稿提示 */
.draft-tip {
  background: rgba(186, 141, 89, 0.9);
  color: #fff;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
}

.draft-icon {
  font-size: 28rpx;
}

.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ai-hint {
  font-size: 24rpx;
  font-weight: normal;
  color: #FF8096;
  background: rgba(186, 141, 89, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.add-sku-btn {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: normal;
}

/* 图片上传 */
.image-upload {
  margin-bottom: 24rpx;
}

.main-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* AI 识别中遮罩 */
.ai-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-loading {
  color: #fff;
  font-size: 26rpx;
}

/* AI 识别标签 */
.ai-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(186, 141, 89, 0.9);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ccc;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.gallery-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gallery-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 8rpx;
}

.gallery-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ccc;
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-textarea {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-item.third {
  flex: 1;
}

.required {
  color: #ff4d4f;
}

/* 分类选择器 */
.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999;
}

/* 场景标签 */
.scene-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scene-chip {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  position: relative;
}

.scene-chip.active {
  color: #fff;
  background: #FF8096;
}

.chip-remove {
  margin-left: 8rpx;
  color: #999;
  font-size: 28rpx;
}

/* 富文本编辑器 */
.editor-wrap {
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  overflow: hidden;
}

.editor-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #e8e8e8;
}

.toolbar-btn {
  height: 64rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #333;
  background: #fff;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.toolbar-btn.italic {
  font-style: italic;
}

.toolbar-btn.active {
  background: #FF8096;
  color: #fff;
  border-color: #FF8096;
}

.editor-content {
  width: 100%;
  min-height: 400rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 商品参数 */
.add-param-btn {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: normal;
}

.params-list {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.param-row {
  display: flex;
  padding: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
  gap: 8rpx;
}

.param-row:last-child {
  border-bottom: none;
}

.param-input {
  flex: 1;
  font-size: 24rpx;
  padding: 8rpx 12rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
}

.param-delete {
  flex: 0 0 50rpx;
  text-align: center;
  color: #ff4d4f;
  font-size: 32rpx;
  line-height: 1;
}

.params-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* SKU 表格 */
.sku-list {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.sku-header {
  display: flex;
  background: #f5f5f5;
  padding: 16rpx 12rpx;
}

.sku-col {
  flex: 1;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.sku-col-action {
  flex: 0 0 60rpx;
}

.sku-row {
  display: flex;
  padding: 12rpx;
  border-top: 1rpx solid #f0f0f0;
  align-items: center;
}

.sku-input {
  flex: 1;
  font-size: 24rpx;
  padding: 8rpx 12rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
  margin: 0 4rpx;
  text-align: center;
}

.sku-delete {
  flex: 0 0 50rpx;
  text-align: center;
  color: #ff4d4f;
  font-size: 32rpx;
  line-height: 1;
}

.sku-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.action-btn.btn-save {
  color: #FF8096;
  background: rgba(255, 128, 150, 0.08);
}

.action-btn.btn-publish {
  color: #fff;
  background: linear-gradient(135deg, #FF8096, #FF6B85);
}

.action-btn.btn-unpublish {
  color: #ff9800;
  background: rgba(255, 152, 0, 0.1);
}

.action-btn.btn-preview {
  color: #FF8096;
  background: rgba(255, 128, 150, 0.08);
}

/* 预览弹窗 */
.preview-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.preview-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.preview-content {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.preview-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.preview-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.preview-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.preview-card .preview-image {
  width: 100%;
  height: 500rpx;
}

.preview-info {
  padding: 24rpx;
}

.preview-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.preview-brief {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.preview-tag {
  font-size: 22rpx;
  color: #FF8096;
  background: rgba(186, 141, 89, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.preview-price {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.price-current {
  font-size: 40rpx;
  color: #E8494A;
  font-weight: 600;
}

.price-original {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

.price-special {
  font-size: 24rpx;
  color: #fff;
  background: #FF8096;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.preview-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F0F0;
}

.preview-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.preview-btn.btn-cancel {
  background: #F5F5F5;
  color: #666;
}

.preview-btn.btn-confirm {
  background: linear-gradient(135deg, #FF8096, #FF6B85);
  color: #fff;
}

/* 分类选择器头部 */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
