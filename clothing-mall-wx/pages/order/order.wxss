/* 全局背景 */
page {
  background-color: #F7F8FA;
}

.container {
  width: 100%;
  box-sizing: border-box;
}

/* 顶部吸顶区域 (Nav + Tabs) */
.header-wrap {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background-color: #FFFFFF;
  z-index: 100;
}

/* 自定义导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px; /* 微信胶囊右侧的安全边距适配 */
  position: relative;
}

.back-btn {
  width: 40px;
  height: 100%;
  display: flex;
  align-items: center;
}

.back-icon {
  width: 10px;
  height: 10px;
  border-left: 1.5px solid #333333;
  border-bottom: 1.5px solid #333333;
  transform: rotate(45deg);
  margin-left: 4px;
}

.nav-title {
  font-size: 17px;
  font-weight: 500;
  color: #333333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-right {
  width: 40px; /* 占位平衡 */
}

/* Tabs 分类栏 */
.tabs {
  display: flex;
  height: 44px; /* 约 88rpx */
  align-items: center;
  justify-content: space-around;
  padding: 0 12rpx;
}

.tab-item {
  flex: auto;
  text-align: center;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item text {
  font-size: 28rpx;
  color: #666666;
  white-space: nowrap;
  font-family: UICTFontTextStyleBody;
}

.tab-item.active text {
  color: #FF8096; /* 截图中的棕色/咖色 */
  font-weight: bold;
}

/* 订单列表 */
.order-list {
  padding: 24rpx;
}

/* 单个订单卡片 */
.order-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

/* 卡片上部：商品信息 */
.goods-info {
  display: flex;
}

.goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #F5F5F5;
}

.goods-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  /* Ensure min-height to push price to bottom if text is short */
  min-height: 160rpx;
}

.detail-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.goods-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  line-height: 40rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  flex: 1;
  margin-right: 24rpx;
}

.goods-status {
  font-size: 24rpx;
  color: #C0C0C0; /* 截图中的浅灰色状态 */
  flex-shrink: 0;
  line-height: 40rpx;
}

.goods-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  line-height: 34rpx;
}

.detail-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: auto;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #FF8096;
}

.price-num {
  font-size: 32rpx;
  color: #FF8096;
  font-weight: 500;
}

.original-price {
  font-size: 22rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.goods-count {
  font-size: 24rpx;
  color: #999999;
}

/* 卡片下部：操作按钮 */
.action-box {
  display: flex;
  justify-content: flex-end;
  margin-top: 32rpx;
}

.btn {
  height: 56rpx;
  line-height: 54rpx; /* 扣除边框 */
  padding: 0 32rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  margin-left: 20rpx;
  box-sizing: border-box;
  text-align: center;
}

.btn-default {
  color: #666666;
  border: 1rpx solid #DEDEDE;
  background-color: #FFFFFF;
}

.btn-primary {
  color: #FFFFFF;
  border: 1rpx solid #FF8096;
  background-color: #FF8096;
}

/* 顶部占位（高度由 inline style 控制） */
.header-placeholder {
  width: 100%;
}

/* 空状态 */
