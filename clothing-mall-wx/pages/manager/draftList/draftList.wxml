<view class="container">
  <!-- 顶部操作栏 -->
  <view class="header">
    <view class="draft-count">共 {{drafts.length}} 个草稿</view>
    <view class="header-actions">
      <view class="clear-btn" bindtap="clearAllDrafts" wx:if="{{drafts.length > 0}}">清空</view>
    </view>
  </view>

  <!-- 草稿列表 -->
  <view class="draft-list" wx:if="{{drafts.length > 0}}">
    <view class="draft-item"
      wx:for="{{drafts}}" wx:key="index"
      bindlongpress="onLongPress"
      bindtap="{{multiSelectMode ? 'onSelectDraft' : 'editDraft'}}"
      data-index="{{index}}">

      <!-- 多选框 -->
      <view class="checkbox" wx:if="{{multiSelectMode}}">
        <view class="checkbox-inner {{selectedIds.indexOf(item.goodsId || 'local_' + index) > -1 ? 'checked' : ''}}"></view>
      </view>

      <image class="draft-image" src="{{item.imageUrl || item.sourceImage || '/static/images/default-goods.png'}}" mode="aspectFill"></image>
      <view class="draft-info">
        <view class="draft-name">{{item.name || '未命名商品'}}</view>
        <view class="draft-meta">
          <text wx:if="{{item.categoryName}}">{{item.categoryName}}</text>
          <text wx:if="{{item.skus && item.skus.length}}"> · {{item.skus.length}}个规格</text>
        </view>
        <view class="draft-time">{{item.savedAt}}</view>
        <view class="draft-actions">
          <view class="btn-edit" catchtap="editDraft" data-index="{{index}}">编辑</view>
          <view class="btn-publish" catchtap="publishDraft" data-index="{{index}}" wx:if="{{item.name}}">上架</view>
          <view class="btn-delete" catchtap="deleteDraft" data-index="{{index}}">删除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 多选模式底部操作栏 -->
  <view class="batch-bar" wx:if="{{multiSelectMode}}">
    <view class="batch-info">已选 {{selectedIds.length}} 件</view>
    <view class="batch-actions">
      <view class="batch-btn btn-publish" bindtap="onBatchPublish">批量上架</view>
      <view class="batch-btn btn-delete" bindtap="onBatchDelete">批量删除</view>
      <view class="batch-btn btn-cancel" bindtap="onExitMultiSelect">取消</view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && drafts.length === 0}}">
    <view class="empty-icon">📝</view>
    <view class="empty-text">暂无草稿</view>
    <view class="create-btn" bindtap="createNew">去创建商品</view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
