@import "../../../styles/manager-common.wxss";

.container {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  /* 占位符，高度由 JS 动态设置 */
}

/* 子 Tab */
.sub-tabs {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.sub-tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.sub-tab-item.active {
  color: #FF8096;
  font-weight: 600;
}

.sub-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #FF8096;
  border-radius: 3rpx;
}

/* ========== 上架表单 ========== */
.upload-section {
  padding-bottom: 160rpx;
}

.section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ai-hint {
  font-size: 24rpx;
  font-weight: normal;
  color: #FF8096;
  background: rgba(186, 141, 89, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.add-sku-btn {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: normal;
}

/* 图片上传 */
.image-upload {
  margin-bottom: 24rpx;
}

.main-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* AI 识别中遮罩 */
.ai-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-loading {
  color: #fff;
  font-size: 26rpx;
}

/* AI 识别标签 */
.ai-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(186, 141, 89, 0.9);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ccc;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.gallery-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.gallery-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 8rpx;
}

.gallery-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ccc;
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.half {
  flex: 1;
}

.form-item.third {
  flex: 1;
  min-width: 0;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-label .required {
  color: #E8494A;
}

.form-input {
  background: transparent;
  padding: 0;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  height: 100%;
  display: flex;
  align-items: center;
}

.input-wrapper {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.input-placeholder {
  color: #999;
  font-size: 28rpx;
}

.form-textarea {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
}

.detail-textarea {
  min-height: 240rpx;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 草稿提示 */
.draft-tip {
  position: fixed;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  right: 24rpx;
  background: rgba(186, 141, 89, 0.9);
  color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.action-btn.btn-save {
  color: #FF8096;
  background: rgba(186, 141, 89, 0.08);
}

.action-btn.btn-publish {
  color: #fff;
  background: linear-gradient(135deg, #FF8096, #96745A);
}

.action-btn.btn-preview {
  color: #FF8096;
  background: rgba(186, 141, 89, 0.08);
}

/* 预览弹窗 */
.preview-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.preview-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.preview-content {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.preview-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.preview-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.preview-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.preview-image {
  width: 100%;
  height: 500rpx;
}

.preview-info {
  padding: 24rpx;
}

.preview-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.preview-brief {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.preview-tag {
  font-size: 22rpx;
  color: #FF8096;
  background: rgba(186, 141, 89, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.preview-price {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.price-current {
  font-size: 40rpx;
  color: #E8494A;
  font-weight: 600;
}

.price-original {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

.price-special {
  font-size: 24rpx;
  color: #fff;
  background: #FF8096;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.preview-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F0F0;
}

.preview-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.preview-btn.btn-cancel {
  background: #F5F5F5;
  color: #666;
}

.preview-btn.btn-confirm {
  background: linear-gradient(135deg, #FF8096, #96745A);
  color: #fff;
}

/* ========== 商品列表 ========== */
.list-section {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.list-tabs {
  display: flex;
  background: #fff;
  padding: 0 40rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.list-tab-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.list-tab-item.active {
  color: #FF8096;
  font-weight: 600;
}

.list-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #FF8096;
  border-radius: 2rpx;
}

.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-input {
  background: #F5F5F5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FDFCFB;
}

.list-header-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.header-btn {
  font-size: 24rpx;
  color: #FF8096;
  padding: 8rpx 20rpx;
  border: 1rpx solid #FF8096;
  border-radius: 24rpx;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

.unpublish-all-btn {
  font-size: 24rpx;
  color: #E8494A;
  padding: 8rpx 20rpx;
  border: 1rpx solid #E8494A;
  border-radius: 24rpx;
}

/* 批量操作栏 */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(186, 141, 89, 0.08);
  border-bottom: 1rpx solid rgba(186, 141, 89, 0.2);
}

.batch-count {
  font-size: 26rpx;
  color: #FF8096;
  font-weight: 500;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.batch-btn.select-all {
  color: #FF8096;
  border: 1rpx solid #FF8096;
}

.batch-btn.delete {
  color: #fff;
  background: #E8494A;
}

.goods-list {
  padding: 0 24rpx;
}

.goods-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  align-items: center;
}

.goods-card.batch-mode {
  padding-left: 12rpx;
}

/* 复选框 */
.goods-checkbox {
  flex: 0 0 auto;
  padding: 16rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  border-color: #FF8096;
  background: #FF8096;
}

.checkbox.checked::after {
  content: '';
  width: 12rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(-45deg) translateY(-2rpx);
}
.box-shadow-fix {
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5F5F5;
}

.goods-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.goods-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.status-tag.status-published {
  color: #67C23A;
  background: rgba(103, 194, 58, 0.1);
}

.status-tag.status-pending {
  color: #E6A23C;
  background: rgba(230, 162, 60, 0.1);
}

.goods-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 8rpx;
}

.retail-price {
  font-size: 32rpx;
  color: #E8494A;
  font-weight: 600;
}

.counter-price {
  font-size: 24rpx;
  color: #ccc;
  text-decoration: line-through;
}

.special-price {
  font-size: 24rpx;
  color: #FF8096;
  background: rgba(186, 141, 89, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.goods-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
  margin-left: 16rpx;
}

.goods-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  background: #F5F5F5;
  color: #666;
  text-align: center;
}

.goods-btn.btn-primary {
  background: rgba(186, 141, 89, 0.1);
  color: #FF8096;
}

.goods-btn.btn-warning {
  background: rgba(232, 73, 74, 0.08);
  color: #E8494A;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 分类选择器 */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-confirm {
  font-size: 28rpx;
  color: #FF8096;
  width: 60rpx;
}

/* 场景标签 Chip */
.scene-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scene-chip {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid transparent;
}

.scene-chip.active {
  background: rgba(186, 141, 89, 0.1);
  color: #FF8096;
  border-color: #FF8096;
}

.scene-chip.add-btn {
  color: #999;
  border: 1rpx dashed #DDD;
  background: transparent;
}

.add-icon {
  margin-right: 8rpx;
}

.chip-remove {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #FF8096;
}

.custom-scene-input {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  gap: 16rpx;
}

.scene-input {
  flex: 1;
  background: #F5F5F5;
  padding: 16rpx 20rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.scene-input-actions {
  display: flex;
  gap: 12rpx;
}

.scene-action-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.scene-action-btn.cancel {
  background: #F5F5F5;
  color: #666;
}

.scene-action-btn.confirm {
  background: #FF8096;
  color: #fff;
}

/* 商品参数 */
.add-param-btn {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: normal;
}

.params-list {
  margin-top: 16rpx;
}

.param-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.param-row:last-child {
  margin-bottom: 0;
}

.param-input {
  background: #F5F5F5;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.param-key {
  flex: 1;
}

.param-value {
  flex: 2;
}

.param-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4f;
  font-size: 32rpx;
  background: rgba(255, 77, 79, 0.08);
  border-radius: 50%;
}

.params-empty {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}
