@import "../../../styles/manager-common.wxss";

.container {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 140rpx;
}

.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-sku-btn {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: normal;
}

/* 图片上传 */
.image-upload {
  margin-bottom: 24rpx;
}

.main-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #ccc;
}

.upload-icon {
  font-size: 64rpx;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.gallery-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gallery-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 8rpx;
}

.gallery-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ccc;
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-textarea {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
}

/* SKU 表格 */
.sku-list {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.sku-header {
  display: flex;
  background: #f5f5f5;
  padding: 16rpx 12rpx;
}

.sku-col {
  flex: 1;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.sku-col-action {
  flex: 0 0 60rpx;
}

.sku-row {
  display: flex;
  padding: 12rpx;
  border-top: 1rpx solid #f0f0f0;
  align-items: center;
}

.sku-input {
  flex: 1;
  font-size: 24rpx;
  padding: 8rpx 12rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
  margin: 0 4rpx;
  text-align: center;
}

.sku-delete {
  flex: 0 0 50rpx;
  text-align: center;
  color: #ff4d4f;
  font-size: 32rpx;
  line-height: 1;
}

.sku-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.action-btn.btn-save {
  color: #FF8096;
  background: rgba(186, 141, 89, 0.08);
}

.action-btn.btn-publish {
  color: #fff;
  background: #FF8096;
}

.action-btn.btn-unpublish {
  color: #ff9800;
  background: rgba(255, 152, 0, 0.1);
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* 表单行 */
.form-row {
  display: flex;
  gap: 16rpx;
}

.form-item.third {
  flex: 1;
}

.required {
  color: #ff4d4f;
}

/* 分类选择器 */
.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999;
}

/* 场景标签 */
.scene-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scene-chip {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  position: relative;
}

.scene-chip.active {
  color: #FF8096;
  background: rgba(186, 141, 89, 0.1);
}

.chip-remove {
  margin-left: 8rpx;
  color: #999;
  font-size: 28rpx;
}

.scene-chip.add-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #FF8096;
  background: transparent;
  border: 1rpx dashed #FF8096;
}

.add-icon {
  font-size: 28rpx;
}

.custom-scene-input {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.scene-input {
  flex: 1;
  background: #f5f5f5;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.scene-input-actions {
  display: flex;
  gap: 12rpx;
}

.scene-action-btn {
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.scene-action-btn.cancel {
  color: #999;
  background: #f5f5f5;
}

.scene-action-btn.confirm {
  color: #fff;
  background: #FF8096;
}

/* 商品详细介绍 */
.detail-textarea {
  height: 240rpx;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 商品参数 */
.add-param-btn {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: normal;
}

.params-list {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.param-row {
  display: flex;
  padding: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
  gap: 8rpx;
}

.param-row:last-child {
  border-bottom: none;
}

.param-input {
  flex: 1;
  font-size: 24rpx;
  padding: 8rpx 12rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
}

.param-delete {
  flex: 0 0 50rpx;
  text-align: center;
  color: #ff4d4f;
  font-size: 32rpx;
  line-height: 1;
}

.params-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 分类选择器头部 */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
