/* 川着 transmute 首页样式 */

.container {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 轮播图 */
.banner {
  width: 100%;
  height: 400rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 活动位横向滚动 */
.activity-scroll {
  white-space: nowrap;
  padding: 20rpx 0;
}

.activity-list {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 16rpx;
}

.activity-item {
  display: inline-block;
  width: 280rpx;
  flex-shrink: 0;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.activity-image {
  width: 280rpx;
  height: 160rpx;
}

.activity-info {
  padding: 16rpx;
}

.activity-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* 通用区块 */
.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 商品网格 */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.goods-item {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.goods-image {
  width: 100%;
  height: 340rpx;
  background: #f9f9f9;
}

.goods-info {
  padding: 16rpx;
}

.goods-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  height: 72rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-brief {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 32rpx;
  color: #f44;
  font-weight: 600;
}

.goods-origin-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

/* 限时特卖 */
.flash-section {
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
}

.flash-scroll {
  white-space: nowrap;
}

.flash-list {
  display: inline-flex;
  padding: 0 4rpx;
  gap: 16rpx;
}

.flash-item {
  display: inline-block;
  width: 240rpx;
  flex-shrink: 0;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(244, 68, 68, 0.1);
}

.flash-image-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
}

.flash-image {
  width: 100%;
  height: 100%;
  background: #f9f9f9;
}

.flash-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #f44 0%, #ff6b6b 100%);
  border-radius: 4rpx;
}

.flash-info {
  padding: 16rpx;
}

.flash-name {
  display: block;
  font-size: 24rpx;
  color: #333;
  height: 66rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.flash-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.flash-price {
  font-size: 28rpx;
  color: #f44;
  font-weight: 600;
}

.flash-origin-price {
  font-size: 20rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.flash-stock {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 穿搭推荐 */
.outfit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.outfit-item {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.outfit-image {
  width: 100%;
  height: 400rpx;
  background: #f9f9f9;
}

.outfit-info {
  padding: 16rpx;
}

.outfit-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.outfit-price {
  font-size: 28rpx;
  color: #f44;
  font-weight: 500;
}

/* 底部安全区 */
.safe-bottom {
  height: 40rpx;
}

/* 动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.goods-item, .outfit-item, .flash-item {
  animation: fadeInUp 0.3s ease both;
}
