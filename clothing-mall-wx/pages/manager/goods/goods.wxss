.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 10rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #667eea;
  border-radius: 3rpx;
}

/* 多选操作栏 */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.batch-info {
  font-size: 26rpx;
  color: #333;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  color: #666;
}

.batch-btn.btn-delete {
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.1);
}

.batch-btn.btn-cancel {
  color: #999;
}

/* 商品列表 */
.goods-list {
  padding: 20rpx;
}

.goods-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  align-items: center;
  transition: background 0.2s;
}

.goods-card.selected {
  background: rgba(102, 126, 234, 0.05);
}

.checkbox {
  padding: 10rpx;
  margin-right: 10rpx;
}

.checkbox-inner {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
}

.checkbox-inner.checked {
  background: #667eea;
  border-color: #667eea;
  position: relative;
}

.checkbox-inner.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  background: #fff;
  border-radius: 50%;
}

.goods-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 180rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.goods-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-tag.status-draft {
  color: #999;
  background: #f5f5f5;
}

.status-tag.status-pending {
  color: #ff9800;
  background: rgba(255, 152, 0, 0.1);
}

.status-tag.status-published {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.goods-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 8rpx;
}

.retail-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.counter-price {
  font-size: 24rpx;
  color: #ccc;
  text-decoration: line-through;
}

/* FAB 添加按钮 */
.fab-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.fab-icon {
  font-size: 36rpx;
  line-height: 1;
}

.fab-text {
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}
