.container{
  height: 100vh;
  box-sizing: border-box;
}
.login-box {
  width: 100%;
  height: auto;
  overflow: hidden;
  padding: 0 40rpx;
  margin-top: 300rpx;
  background: #f4f4f4;
  box-sizing: border-box;
}

/* 重置微信原生 button 默认样式 */
button {
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}
button::after {
  display: none;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: #f4f4f4;
  z-index: 999;
}

.nav-inner {
  height: 48px;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.nav-left,
.nav-right {
  width: 56px;
  height: 48px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-left-hover {
  opacity: 0.6;
}

.arrow {
  width: 12px;
  height: 12px;
  border-left: 2px solid #333;
  border-bottom: 2px solid #333;
  transform: rotate(45deg);
}

.nav-center {
  flex: 1;
  height: 48px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-title {
  max-width: 70%;
  font-size: 17px;
  color: #333;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.wx-login-btn {
  width: 90%;
  margin: 60rpx auto 40rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  color: #fff;
  border-radius: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  letter-spacing: 3rpx;
}

.account-login-btn {
  width: 90%;
  margin: 0 auto;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  color: #fff;
  border-radius: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  letter-spacing: 3rpx;
  background: #006699;
}
