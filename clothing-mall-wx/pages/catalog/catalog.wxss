/* 商品列表页样式 */
page {
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-input {
  display: flex;
  align-items: center;
  height: 64rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-text {
  font-size: 26rpx;
  color: #999;
}

/* 分类 Tab */
.category-tabs {
  white-space: nowrap;
  padding: 16rpx 0;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #333;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #333;
  border-radius: 2rpx;
}

/* 商品滚动区域 */
.goods-scroll {
  flex: 1;
  height: 0;
}

/* 瀑布流 */
.goods-waterfall {
  display: flex;
  padding: 16rpx;
  gap: 16rpx;
}

.goods-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goods-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.goods-image {
  width: 100%;
  min-height: 200rpx;
  background: #f9f9f9;
}

.goods-info {
  padding: 16rpx;
}

.goods-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  min-height: 72rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-brief {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.goods-price {
  font-size: 32rpx;
  color: #f44;
  font-weight: 600;
}

.goods-origin-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

/* 加载状态 */
.load-status {
  padding: 30rpx 0;
  text-align: center;
}

.loading text, .no-more text {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
