page {
  height: 100%;
  width: 100%;
  background: #f5f5f5;
}

.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 用户信息区 */
.profile-info {
  background: linear-gradient(135deg, #ab956d 0%, #8b7355 100%);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 60rpx 40rpx 80rpx;
  position: relative;
}

.profile-info .bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  opacity: 0.1;
}

.profile-info .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.profile-info .info {
  position: relative;
  z-index: 1;
}

.profile-info .name {
  display: block;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.profile-info .desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
}

/* 订单区域 */
.order-section {
  background: #fff;
  margin: -40rpx 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.section-more .arrow {
  margin-left: 8rpx;
}

.order-menu {
  display: flex;
  justify-content: space-around;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 16rpx 0;
}

.order-badge {
  position: absolute;
  top: 0;
  right: 10rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  text-align: center;
}

.order-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
}

.order-text {
  font-size: 24rpx;
  color: #666;
}

/* 功能菜单 */
.menu-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-row {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.menu-row:not(:last-child) {
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  position: relative;
}

.coupon-badge {
  position: absolute;
  top: 4rpx;
  right: 16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  text-align: center;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}

.menu-text {
  font-size: 24rpx;
  color: #666;
}

/* 退出登录 */
.logout {
  margin: 40rpx 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border-radius: 16rpx;
  color: #ff6b6b;
  font-size: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
