.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.order-list {
  padding: 20rpx;
}

.order-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-sn {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
  background: rgba(102, 126, 234, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.order-info {
  padding: 16rpx 30rpx;
  background: #fafafa;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.info-value {
  font-size: 24rpx;
  color: #333;
}

.order-content {
  padding: 20rpx 30rpx;
}

.goods-item {
  display: flex;
  margin-bottom: 20rpx;
}

.goods-item:last-child {
  margin-bottom: 0;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-spec {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.goods-price-num {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.goods-price {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.goods-num {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  padding: 16rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: right;
}

.order-total {
  font-size: 26rpx;
  color: #333;
}

.order-total .price {
  color: #ff4d4f;
  font-weight: 600;
}

.order-actions {
  padding: 16rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #ddd;
  color: #666;
  background: #fff;
}

.action-btn.btn-primary {
  color: #667eea;
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
}

.action-btn.btn-danger {
  color: #ff4d4f;
  border-color: #ff4d4f;
  background: rgba(255, 77, 79, 0.05);
}

.action-btn.btn-warning {
  color: #ff9800;
  border-color: #ff9800;
  background: rgba(255, 152, 0, 0.05);
}

.action-btn.btn-cancel {
  color: #999;
  border-color: #ddd;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}
