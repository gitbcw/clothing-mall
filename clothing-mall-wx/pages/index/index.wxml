<!-- index.wxml - 川着 transmute 首页 -->
<view class="container">
  <!-- 轮播图 -->
  <swiper
    class="banner"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    interval="4000"
    duration="500"
    circular="{{true}}"
  >
    <swiper-item wx:for="{{banner}}" wx:key="id">
      <navigator
        wx:if="{{item.linkType === 'goods'}}"
        url="/pages/goods/goods?id={{item.link}}"
      >
        <image class="banner-image" src="{{item.url}}" mode="aspectFill" />
      </navigator>
      <navigator
        wx:elif="{{item.linkType === 'category'}}"
        url="/pages/category/category?id={{item.link}}"
      >
        <image class="banner-image" src="{{item.url}}" mode="aspectFill" />
      </navigator>
      <image wx:else class="banner-image" src="{{item.url}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <!-- 活动位（横向滚动） -->
  <scroll-view scroll-x class="activity-scroll" wx:if="{{activities.length > 0}}">
    <view class="activity-list">
      <navigator
        class="activity-item"
        wx:for="{{activities}}"
        wx:key="id"
        url="/pages/goods/goods?id={{item.goodsId}}&flashSaleId={{item.flashSaleId}}"
      >
        <image class="activity-image" src="{{item.image}}" mode="aspectFill" />
        <view class="activity-info">
          <text class="activity-title">{{item.title}}</text>
          <text class="activity-desc">{{item.desc}}</text>
        </view>
      </navigator>
    </view>
  </scroll-view>

  <!-- 热销款 -->
  <view class="section" wx:if="{{hotGoods.length > 0}}">
    <view class="section-header">
      <text class="section-title">热销款</text>
      <navigator url="/pages/hotGoods/hotGoods" class="section-more">更多</navigator>
    </view>
    <view class="goods-grid">
      <navigator
        class="goods-item"
        wx:for="{{hotGoods}}"
        wx:key="id"
        url="/pages/goods/goods?id={{item.id}}"
      >
        <image class="goods-image" src="{{item.picUrl}}" mode="aspectFill" lazy-load />
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-brief" wx:if="{{item.brief}}">{{item.brief}}</text>
          <view class="goods-price-row">
            <text class="goods-price">¥{{item.retailPrice}}</text>
            <text class="goods-origin-price" wx:if="{{item.counterPrice > item.retailPrice}}">¥{{item.counterPrice}}</text>
          </view>
        </view>
      </navigator>
    </view>
  </view>

  <!-- 限时特卖 -->
  <view class="section flash-section" wx:if="{{flashSaleList.length > 0}}">
    <view class="section-header">
      <view class="section-title-wrap">
        <text class="section-title">限时特卖</text>
        <text class="section-subtitle">限时优惠，手慢无</text>
      </view>
      <navigator url="/pages/flashSale/flashSale" class="section-more">更多</navigator>
    </view>
    <scroll-view scroll-x class="flash-scroll">
      <view class="flash-list">
        <navigator
          class="flash-item"
          wx:for="{{flashSaleList}}"
          wx:key="id"
          url="/pages/goods/goods?id={{item.goodsId}}&flashSaleId={{item.id}}"
        >
          <view class="flash-image-wrap">
            <image class="flash-image" src="{{item.picUrl}}" mode="aspectFill" lazy-load />
            <view class="flash-tag">特卖</view>
          </view>
          <view class="flash-info">
            <text class="flash-name">{{item.goodsName}}</text>
            <view class="flash-price-row">
              <text class="flash-price">¥{{item.flashPrice}}</text>
              <text class="flash-origin-price">¥{{item.originalPrice}}</text>
            </view>
            <view class="flash-stock">
              <text>已售 {{item.flashSales || 0}}</text>
              <text> | </text>
              <text>剩余 {{item.flashStock}}</text>
            </view>
          </view>
        </navigator>
      </view>
    </scroll-view>
  </view>

  <!-- 穿搭推荐 -->
  <view class="section" wx:if="{{outfitList.length > 0}}">
    <view class="section-header">
      <text class="section-title">穿搭推荐</text>
      <navigator url="/pages/catalog/catalog?category=outfit" class="section-more">更多</navigator>
    </view>
    <view class="outfit-grid">
      <navigator
        class="outfit-item"
        wx:for="{{outfitList}}"
        wx:key="id"
        url="/pages/goods/goods?id={{item.id}}"
      >
        <image class="outfit-image" src="{{item.picUrl}}" mode="aspectFill" lazy-load />
        <view class="outfit-info">
          <text class="outfit-name">{{item.name}}</text>
          <text class="outfit-price">¥{{item.retailPrice}}</text>
        </view>
      </navigator>
    </view>
  </view>

  <!-- 配饰 -->
  <view class="section" wx:if="{{accessoryList.length > 0}}">
    <view class="section-header">
      <text class="section-title">配饰</text>
      <navigator url="/pages/catalog/catalog?category=accessory" class="section-more">更多</navigator>
    </view>
    <view class="goods-grid">
      <navigator
        class="goods-item"
        wx:for="{{accessoryList}}"
        wx:key="id"
        url="/pages/goods/goods?id={{item.id}}"
      >
        <image class="goods-image" src="{{item.picUrl}}" mode="aspectFill" lazy-load />
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <view class="goods-price-row">
            <text class="goods-price">¥{{item.retailPrice}}</text>
          </view>
        </view>
      </navigator>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
