<!-- SKU 选择器组件 - 服装店专用（颜色+尺码） -->
<view class="sku-picker" wx:if="{{visible}}">
  <view class="sku-mask" bindtap="onClose"></view>
  <view class="sku-container">
    <!-- 关闭按钮 -->
    <view class="sku-close" bindtap="onClose">
      <text class="close-icon">×</text>
    </view>

    <!-- 商品信息 -->
    <view class="sku-header">
      <image class="sku-image" src="{{selectedSku.imageUrl || goodsImage}}" mode="aspectFill"></image>
      <view class="sku-info">
        <view class="sku-price">￥{{selectedSku.price || goodsPrice}}</view>
        <view class="sku-stock" wx:if="{{selectedSku}}">库存：{{selectedSku.stock}}件</view>
        <view class="sku-selected" wx:if="{{selectedColor && selectedSize}}">
          已选：{{selectedColor}} / {{selectedSize}}
        </view>
        <view class="sku-selected" wx:else>请选择颜色和尺码</view>
      </view>
    </view>

    <!-- 颜色选择 -->
    <view class="sku-section" wx:if="{{colors.length > 0}}">
      <view class="sku-section-title">颜色</view>
      <view class="sku-options">
        <view
          wx:for="{{colors}}"
          wx:key="name"
          class="sku-option color-option {{selectedColor === item.name ? 'selected' : ''}}"
          bindtap="onSelectColor"
          data-color="{{item.name}}"
          data-image="{{item.image}}">
          <image wx:if="{{item.image}}" class="color-image" src="{{item.image}}" mode="aspectFill"></image>
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 尺码选择 -->
    <view class="sku-section" wx:if="{{availableSizes.length > 0}}">
      <view class="sku-section-title">尺码</view>
      <view class="sku-options">
        <view
          wx:for="{{availableSizes}}"
          wx:key="size"
          class="sku-option size-option {{selectedSize === item.size ? 'selected' : ''}} {{item.stock <= 0 ? 'disabled' : ''}}"
          bindtap="onSelectSize"
          data-size="{{item.size}}"
          data-stock="{{item.stock}}">
          {{item.size}}
        </view>
      </view>
    </view>

    <!-- 数量选择 -->
    <view class="sku-section">
      <view class="sku-section-title">数量</view>
      <view class="sku-quantity">
        <view class="quantity-btn {{quantity <= 1 ? 'disabled' : ''}}" bindtap="onDecrease">-</view>
        <input class="quantity-input" type="number" value="{{quantity}}" disabled />
        <view class="quantity-btn {{quantity >= maxQuantity ? 'disabled' : ''}}" bindtap="onIncrease">+</view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="sku-footer">
      <view class="sku-btn btn-cart" bindtap="onAddToCart">加入购物车</view>
      <view class="sku-btn btn-buy" bindtap="onBuyNow">立即购买</view>
    </view>
  </view>
</view>
