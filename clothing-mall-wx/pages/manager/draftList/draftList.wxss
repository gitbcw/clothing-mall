.container {
  min-height: 100vh;
  background-color: #F7F8FA;
}

.header {
  background: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.draft-count {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.clear-btn {
  font-size: 26rpx;
  color: #E8494A;
  padding: 6rpx 16rpx;
}

/* 多选模式底部操作栏 */
.batch-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}

.batch-info {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: #F7F3EF;
  color: #BA8D59;
}

.batch-btn.btn-publish {
  background: #BA8D59;
  color: #fff;
}

.batch-btn.btn-delete {
  color: #E8494A;
  background: rgba(232, 73, 74, 0.08);
}

.batch-btn.btn-cancel {
  color: #999;
  background: #F5F5F5;
}

.draft-list {
  padding: 20rpx 24rpx;
}

.draft-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.checkbox {
  flex-shrink: 0;
}

.checkbox-inner {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
}

.checkbox-inner.checked {
  background: #BA8D59;
  border-color: #BA8D59;
  position: relative;
}

.checkbox-inner.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  background: #fff;
  border-radius: 50%;
}

.draft-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  flex-shrink: 0;
}

.draft-info {
  flex: 1;
  min-width: 0;
}

.draft-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.draft-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: flex;
  gap: 12rpx;
}

.draft-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.draft-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-edit, .btn-delete, .btn-publish {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: none;
}

.btn-edit {
  background: rgba(186, 141, 89, 0.1);
  color: #BA8D59;
}

.btn-publish {
  background: #BA8D59;
  color: #fff;
}

.btn-delete {
  background: #F5F5F5;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.create-btn {
  background: linear-gradient(135deg, #BA8D59 0%, #96745A 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
