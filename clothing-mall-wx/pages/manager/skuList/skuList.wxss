.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.search-bar {
  background: #fff;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
}

.filter-btn {
  padding: 16rpx 24rpx;
  background: #667eea;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.filter-panel {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.filter-label {
  font-size: 28rpx;
  color: #333;
}

.filter-value {
  font-size: 28rpx;
  color: #666;
}

.sku-list {
  padding: 20rpx;
}

.sku-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.sku-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.sku-info {
  flex: 1;
  min-width: 0;
}

.sku-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sku-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: flex;
  gap: 16rpx;
}

.sku-status {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-top: 8rpx;
}

.status-draft {
  background: #fff3e0;
  color: #ff9800;
}

.status-online {
  background: #e8f5e9;
  color: #4caf50;
}

.status-offline {
  background: #fce4ec;
  color: #e91e63;
}

.sku-actions {
  flex-shrink: 0;
}

.action-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  border: none;
}

.action-btn.online {
  background: #667eea;
  color: #fff;
}

.action-btn.offline {
  background: #f5f5f5;
  color: #666;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.empty {
  padding: 100rpx 40rpx;
}
