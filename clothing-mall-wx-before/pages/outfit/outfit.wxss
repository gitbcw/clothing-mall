page {
  height: 100%;
  background: #f4f4f4;
}

.container {
  min-height: 100%;
  background: #f4f4f4;
}

/* 海报轮播 */
.outfit-banner {
  background: #fff;
  padding: 20rpx;
}

.banner-swiper {
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
  background: #eee;
}

.banner-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
}

.banner-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.banner-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
}

/* 热门穿搭列表 */
.outfit-list {
  padding: 20rpx;
}

.section-title {
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.outfit-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.outfit-card {
  width: calc(50% - 20rpx);
  margin: 0 10rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.outfit-poster {
  position: relative;
  height: 300rpx;
}

.outfit-image {
  width: 100%;
  height: 100%;
  background: #eee;
}

.outfit-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 6rpx 16rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.outfit-info {
  padding: 16rpx;
}

.outfit-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.outfit-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.outfit-goods-count {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #666;
}

/* 加载状态 */
.loading-status {
  padding: 30rpx;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.finished-text {
  font-size: 26rpx;
  color: #ccc;
}

/* 空状态 */
.empty-status {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 穿搭详情弹窗 */
.outfit-detail {
  height: 100vh;
  display: flex;
  background: #f4f4f4;
}

.left-panel {
  width: 100%;
  height: 100%;
}

.left-header {
  background: #fff;
  padding: 20rpx;
}

.detail-poster {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  background: #eee;
}

.detail-info {
  margin-top: 20rpx;
}

.detail-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.detail-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.goods-list-title {
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  background: #fff;
  margin-top: 20rpx;
}

.fixed-goods-list {
  background: #fff;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #eee;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
}

.goods-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  display: block;
  font-size: 30rpx;
  color: #ff4444;
  margin-top: 10rpx;
}

.goods-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
  text-align: center;
}

.add-cart {
  background: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}

.buy-now {
  background: #ff4444;
  color: #fff;
}