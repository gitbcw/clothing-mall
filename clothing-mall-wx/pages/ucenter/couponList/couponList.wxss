page {
  background: #f4f4f4;
  min-height: 100%;
}

.container {
  background: #f4f4f4;
  min-height: 100%;
}

/* ================================================================
   Tab Bar
   ================================================================ */
.tab-bar {
  display: flex;
  background: #fff;
  height: 88rpx;
  position: relative;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 30rpx;
  color: #999;
  transition: color 0.3s;
}

.tab-item.active .tab-text {
  color: #333;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #FF8096;
  transform: translateX(-50%);
  transition: left 0.3s ease;
}

/* ================================================================
   Exchange Bar
   ================================================================ */
.exchange-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  gap: 16rpx;
}

.exchange-field {
  flex: 1;
  position: relative;
}

.exchange-input {
  width: 100%;
  height: 72rpx;
  background: #f4f4f4;
  border-radius: 36rpx;
  padding: 0 64rpx 0 32rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.exchange-clear {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  background: #ccc;
  border-radius: 50%;
}

.exchange-btn {
  height: 72rpx;
  padding: 0 40rpx;
  background: #FF8096;
  border-radius: 36rpx;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.exchange-btn:active {
  opacity: 0.85;
}

.exchange-btn.disabled {
  background: #FFD4DC;
  color: rgba(255, 255, 255, 0.8);
}

/* ================================================================
   Empty State
   ================================================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF5F7, #FFE8EC);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}

.empty-ticket {
  width: 52rpx;
  height: 36rpx;
  border: 4rpx solid #FFD4DC;
  border-radius: 6rpx;
  position: relative;
}

.empty-ticket-line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  border-left: 2rpx dashed #FFD4DC;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* ================================================================
   Coupon List
   ================================================================ */
.coupon-list {
  padding: 24rpx;
}

.coupon-card {
  position: relative;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

/* Ticket notches */
.coupon-card::before,
.coupon-card::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #f4f4f4;
  z-index: 2;
}

.coupon-card::before {
  left: 176rpx;
  top: -12rpx;
}

.coupon-card::after {
  left: 176rpx;
  bottom: -12rpx;
}

/* Active coupon */
.coupon-active {
  background: linear-gradient(135deg, #FF8096, #FFB6C1);
}

/* Expired/Used coupon */
.coupon-expired {
  background: #e8e8e8;
}

/* Tag badge */
.coupon-tag {
  position: absolute;
  top: 0;
  left: 0;
  font-size: 20rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 16rpx 0 12rpx 0;
  z-index: 1;
}

.coupon-expired .coupon-tag {
  background: rgba(0, 0, 0, 0.08);
  color: #999;
}

/* Body */
.coupon-body {
  display: flex;
  padding: 36rpx 24rpx 28rpx;
}

.coupon-left {
  width: 200rpx;
  flex-shrink: 0;
  display: flex;
  align-items: baseline;
  justify-content: center;
  border-right: 2rpx dashed rgba(255, 255, 255, 0.3);
  padding-right: 20rpx;
}

.coupon-expired .coupon-left {
  border-right-color: rgba(0, 0, 0, 0.1);
}

.coupon-symbol {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-right: 2rpx;
}

.coupon-expired .coupon-symbol {
  color: #999;
}

.coupon-amount {
  font-size: 60rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

.coupon-expired .coupon-amount {
  color: #999;
}

.coupon-right {
  flex: 1;
  padding-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-expired .coupon-name {
  color: #999;
}

.coupon-min {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 10rpx;
}

.coupon-expired .coupon-min {
  color: #bbb;
}

.coupon-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.coupon-expired .coupon-time {
  color: #ccc;
}

/* Footer */
.coupon-footer {
  border-top: 2rpx dashed rgba(255, 255, 255, 0.2);
  padding: 14rpx 24rpx;
}

.coupon-expired .coupon-footer {
  border-top-color: rgba(0, 0, 0, 0.06);
}

.coupon-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.coupon-expired .coupon-desc {
  color: #bbb;
}

/* ================================================================
   Footer
   ================================================================ */
.list-footer {
  padding: 32rpx 0 64rpx;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}
