.container {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 140rpx;
}

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #BA8D59;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #BA8D59;
  border-radius: 3rpx;
}

/* 多选操作栏 */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.batch-info {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: #F7F3EF;
  color: #BA8D59;
}

.batch-btn.btn-delete {
  color: #E8494A;
  background: rgba(232, 73, 74, 0.08);
}

.batch-btn.btn-cancel {
  color: #999;
  background: #F5F5F5;
}

/* 商品列表 */
.goods-list {
  padding: 20rpx 24rpx;
}

.goods-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: background 0.2s;
}

.goods-card.selected {
  background: rgba(186, 141, 89, 0.06);
}

.checkbox {
  padding: 10rpx;
  margin-right: 10rpx;
}

.checkbox-inner {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
}

.checkbox-inner.checked {
  background: #BA8D59;
  border-color: #BA8D59;
  position: relative;
}

.checkbox-inner.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  background: #fff;
  border-radius: 50%;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5F5F5;
}

.goods-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 160rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.goods-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.status-tag.status-draft {
  color: #999;
  background: #F5F5F5;
}

.status-tag.status-pending {
  color: #E6A23C;
  background: rgba(230, 162, 60, 0.1);
}

.status-tag.status-published {
  color: #67C23A;
  background: rgba(103, 194, 58, 0.1);
}

.goods-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 8rpx;
}

.retail-price {
  font-size: 32rpx;
  color: #E8494A;
  font-weight: 600;
}

.counter-price {
  font-size: 24rpx;
  color: #ccc;
  text-decoration: line-through;
}

/* FAB 添加按钮 */
.fab-btn {
  position: fixed;
  bottom: 140rpx;
  right: 36rpx;
  background: linear-gradient(135deg, #BA8D59, #96745A);
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(186, 141, 89, 0.4);
}

.fab-icon {
  font-size: 36rpx;
  line-height: 1;
}

.fab-text {
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}
