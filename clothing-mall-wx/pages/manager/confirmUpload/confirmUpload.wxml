<view class="container">
  <!-- 图片预览 -->
  <view class="image-preview" wx:if="{{imageUrl}}">
    <image src="{{imageUrl}}" mode="aspectFit" class="preview-img"></image>
    <view class="ai-badge" wx:if="{{!manual}}">
      <text>AI 识别</text>
      <text class="confidence">{{recognizeResult.confidence}}%</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-section">
    <view class="form-item">
      <text class="label">商品名称</text>
      <input class="input" placeholder="请输入商品名称" value="{{recognizeResult.name}}" data-field="name" bindinput="onInputChange" />
    </view>

    <view class="form-item">
      <text class="label">分类</text>
      <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker">
          {{categoryOptions[categoryIndex]}}
          <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">颜色</text>
      <picker mode="selector" range="{{colorOptions}}" value="{{colorIndex}}" bindchange="onColorChange">
        <view class="picker">
          {{colorOptions[colorIndex]}}
          <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">尺码</text>
      <picker mode="selector" range="{{sizeOptions}}" value="{{sizeIndex}}" bindchange="onSizeChange">
        <view class="picker">
          {{sizeOptions[sizeIndex]}}
          <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">材质</text>
      <input class="input" placeholder="请输入材质" value="{{recognizeResult.material}}" data-field="material" bindinput="onInputChange" />
    </view>

    <view class="form-item">
      <text class="label">风格</text>
      <picker mode="selector" range="{{styleOptions}}" value="{{styleIndex}}" bindchange="onStyleChange">
        <view class="picker">
          {{styleOptions[styleIndex]}}
          <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">季节</text>
      <picker mode="selector" range="{{seasonOptions}}" value="{{seasonIndex}}" bindchange="onSeasonChange">
        <view class="picker">
          {{seasonOptions[seasonIndex]}}
          <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">简介</text>
      <textarea class="textarea" placeholder="请输入商品简介" value="{{recognizeResult.brief}}" data-field="brief" bindinput="onInputChange" maxlength="200"></textarea>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions">
    <button class="btn-draft" bindtap="saveDraft">暂存草稿</button>
    <button class="btn-submit" type="primary" bindtap="submitSku" loading="{{submitting}}" disabled="{{submitting}}">确认创建</button>
  </view>
</view>
