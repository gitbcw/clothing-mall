.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 订单卡片头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 20rpx;
}

.order-sn {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 24rpx;
  color: #FF8096;
  font-weight: 500;
}

/* 订单卡片底部 */
.order-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.order-total {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}