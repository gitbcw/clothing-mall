.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-tip {
  font-size: 24rpx;
  color: #999;
}

.upload-area {
  display: flex;
  flex-wrap: wrap;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-icon-text {
  font-size: 64rpx;
  color: #999;
  line-height: 1;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: #ff6b6b;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item:nth-child(3n) {
  margin-right: 0;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.upload-status {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-status.success {
  background: rgba(76, 175, 80, 0.8);
}

.upload-status.fail {
  background: rgba(244, 67, 54, 0.8);
}

.btn-area {
  padding: 40rpx 0;
}

.upload-btn-main {
  background: linear-gradient(135deg, #ab956d 0%, #8b7355 100%);
  color: #fff;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
}

.upload-btn-main[disabled] {
  background: #ccc;
  color: #fff;
}

.stats {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: #666;
}
