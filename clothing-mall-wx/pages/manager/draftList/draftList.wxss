.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.draft-count {
  font-size: 28rpx;
  color: #666;
}

.clear-btn {
  font-size: 26rpx;
  color: #ff4d4f;
}

.draft-list {
  padding: 20rpx;
}

.draft-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.draft-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.draft-info {
  flex: 1;
  min-width: 0;
}

.draft-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.draft-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: flex;
  gap: 12rpx;
}

.draft-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.draft-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.btn-edit, .btn-delete {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: none;
}

.btn-edit {
  background: #667eea;
  color: #fff;
}

.btn-delete {
  background: #f5f5f5;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.create-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
